{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A race car representing a salesperson's progress.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the salesperson." },
        "color": { "type": "string", "description": "The hex color of the car." },
        "sales": { "type": "integer", "description": "The number of sales (0-30)." },
        "updatedAt": { "type": "integer", "description": "Timestamp of the last update." },
        "createdAt": { "type": "integer", "description": "Timestamp of creation." }
      },
      "required": ["name", "color", "sales", "updatedAt", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An authorized administrator.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "The email of the admin." },
        "role": { "type": "string", "enum": ["admin", "main_admin"], "description": "The role of the admin." }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/cars/{carId}": {
      "schema": "Car",
      "description": "Collection of race cars."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of authorized administrators."
    }
  }
}
