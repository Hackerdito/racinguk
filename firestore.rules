rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: cars
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - Salesperson name
    //   - color: string (required) - Car hex color
    //   - sales: number (required) - Current sales (0-30)
    //   - updatedAt: number (required) - Last update timestamp
    //   - createdAt: number (required) - Creation timestamp
    //
    // Collection: admins
    // Document ID: user UID
    // Fields:
    //   - email: string (required) - Admin email
    //   - role: string (required) - 'admin' or 'main_admin'
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isMainAdmin() {
      return isAuthenticated() && 
        ('email' in request.auth.token) &&
        (request.auth.token.email == "gerito.diseno@gmail.com");
    }

    function isAdmin() {
      return isMainAdmin() || 
        (isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Domain Validators
    function isValidCar(data) {
      return data.keys().hasAll(['name', 'color', 'sales', 'updatedAt', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.color is string && data.color.matches('^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$') &&
             data.sales is number && data.sales >= 0 && data.sales <= 10000 &&
             data.updatedAt is number &&
             data.createdAt is number;
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'main_admin'];
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['goal']) &&
             data.goal is number && data.goal > 0 && data.goal <= 10000;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['weekName', 'date', 'goal', 'results']) &&
             data.weekName is string && data.weekName.size() > 0 && data.weekName.size() < 100 &&
             data.date is number &&
             data.goal is number && data.goal > 0 &&
             data.results is list;
    }

    // Rules
    match /cars/{carId} {
      allow read: if true; // Public can see the race
      allow create: if isAdmin() && isValidCar(request.resource.data);
      allow update: if isAdmin() && isValidCar(request.resource.data);
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated() && (request.auth.uid == adminId || isMainAdmin());
      allow create: if isMainAdmin() && isValidAdmin(request.resource.data);
      allow update: if isMainAdmin() && isValidAdmin(request.resource.data);
      allow delete: if isMainAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidReport(request.resource.data);
      allow update: if false; // Reports should be immutable
      allow delete: if isMainAdmin();
    }
  }
}
